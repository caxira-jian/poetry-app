# Client-side display/meta (safe to expose)
VITE_DEFAULT_API_PROVIDER=glm
VITE_DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_DEFAULT_API_MODEL=glm-4.7
VITE_DEFAULT_API_TEMPERATURE=0.3

# Server-side secret (must NOT use VITE_ prefix)
DEFAULT_API_PROVIDER=glm
DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DEFAULT_API_MODEL=glm-4.7
DEFAULT_API_KEY=your_server_side_secret_key
DEFAULT_API_TEMPERATURE=0.3

# -----------------------------
# Quick switch presets (copy one full pair to active values above)

# Qwen
# VITE_DEFAULT_API_PROVIDER=qwen
# VITE_DEFAULT_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VITE_DEFAULT_API_MODEL=qwen-plus
# VITE_DEFAULT_API_TEMPERATURE=0.3
# DEFAULT_API_PROVIDER=qwen
# DEFAULT_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEFAULT_API_MODEL=qwen-plus
# DEFAULT_API_KEY=your_qwen_key
# DEFAULT_API_TEMPERATURE=0.3

# DeepSeek
# VITE_DEFAULT_API_PROVIDER=deepseek
# VITE_DEFAULT_API_BASE_URL=https://api.deepseek.com/v1
# VITE_DEFAULT_API_MODEL=deepseek-chat
# VITE_DEFAULT_API_TEMPERATURE=0.3
# DEFAULT_API_PROVIDER=deepseek
# DEFAULT_API_BASE_URL=https://api.deepseek.com/v1
# DEFAULT_API_MODEL=deepseek-chat
# DEFAULT_API_KEY=your_deepseek_key
# DEFAULT_API_TEMPERATURE=0.3

# GLM
# VITE_DEFAULT_API_PROVIDER=glm
# VITE_DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VITE_DEFAULT_API_MODEL=glm-4.7
# VITE_DEFAULT_API_TEMPERATURE=0.3
# DEFAULT_API_PROVIDER=glm
# DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# DEFAULT_API_MODEL=glm-4.7
# DEFAULT_API_KEY=your_glm_key
# DEFAULT_API_TEMPERATURE=0.3

# Moonshot (OpenAI-compatible)
# VITE_DEFAULT_API_PROVIDER=custom
# VITE_DEFAULT_API_BASE_URL=https://api.moonshot.cn/v1
# VITE_DEFAULT_API_MODEL=moonshot-v1-8k
# VITE_DEFAULT_API_TEMPERATURE=0.3
# DEFAULT_API_PROVIDER=custom
# DEFAULT_API_BASE_URL=https://api.moonshot.cn/v1
# DEFAULT_API_MODEL=moonshot-v1-8k
# DEFAULT_API_KEY=your_moonshot_key
# DEFAULT_API_TEMPERATURE=0.3

# OpenAI
# VITE_DEFAULT_API_PROVIDER=custom
# VITE_DEFAULT_API_BASE_URL=https://api.openai.com/v1
# VITE_DEFAULT_API_MODEL=gpt-4o-mini
# VITE_DEFAULT_API_TEMPERATURE=0.3
# DEFAULT_API_PROVIDER=custom
# DEFAULT_API_BASE_URL=https://api.openai.com/v1
# DEFAULT_API_MODEL=gpt-4o-mini
