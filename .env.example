# Default API profile (choose one provider block)
# Supported provider values: qwen / deepseek / glm / custom

# Active defaults (edit these 5 lines)
VITE_DEFAULT_API_PROVIDER=glm
VITE_DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_DEFAULT_API_MODEL=glm-4.7
VITE_DEFAULT_API_KEY=your_default_api_key
VITE_DEFAULT_API_TEMPERATURE=0.3

# -----------------------------
# Quick switch presets
# Uncomment one block and replace the active defaults above.

# Qwen
# VITE_DEFAULT_API_PROVIDER=qwen
# VITE_DEFAULT_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Models: qwen-plus / qwen-turbo / qwen-max
# VITE_DEFAULT_API_MODEL=qwen-plus
# VITE_DEFAULT_API_KEY=your_qwen_key
# VITE_DEFAULT_API_TEMPERATURE=0.3

# DeepSeek
# VITE_DEFAULT_API_PROVIDER=deepseek
# VITE_DEFAULT_API_BASE_URL=https://api.deepseek.com/v1
# Models: deepseek-chat / deepseek-reasoner
# VITE_DEFAULT_API_MODEL=deepseek-chat
# VITE_DEFAULT_API_KEY=your_deepseek_key
# VITE_DEFAULT_API_TEMPERATURE=0.3

# GLM
# VITE_DEFAULT_API_PROVIDER=glm
# VITE_DEFAULT_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Models: glm-4.7 / glm-4-plus / glm-4-air
# VITE_DEFAULT_API_MODEL=glm-4.7
# VITE_DEFAULT_API_KEY=your_glm_key
# VITE_DEFAULT_API_TEMPERATURE=0.3

# Moonshot (OpenAI-compatible)
# VITE_DEFAULT_API_PROVIDER=custom
# VITE_DEFAULT_API_BASE_URL=https://api.moonshot.cn/v1
# Models: moonshot-v1-8k / moonshot-v1-32k / moonshot-v1-128k
# VITE_DEFAULT_API_MODEL=moonshot-v1-8k
# VITE_DEFAULT_API_KEY=your_moonshot_key
# VITE_DEFAULT_API_TEMPERATURE=0.3

# OpenAI
# VITE_DEFAULT_API_PROVIDER=custom
# VITE_DEFAULT_API_BASE_URL=https://api.openai.com/v1
# Models: gpt-4o / gpt-4o-mini / o3-mini
# VITE_DEFAULT_API_MODEL=gpt-4o-mini
# VITE_DEFAULT_API_KEY=your_openai_key
# VITE_DEFAULT_API_TEMPERATURE=0.3

# OpenRouter (OpenAI-compatible)
# VITE_DEFAULT_API_PROVIDER=custom
# VITE_DEFAULT_API_BASE_URL=https://openrouter.ai/api/v1
# Models: openai/gpt-4o-mini / anthropic/claude-3.5-sonnet / google/gemini-2.0-flash-001
# VITE_DEFAULT_API_MODEL=openai/gpt-4o-mini
# VITE_DEFAULT_API_KEY=your_openrouter_key
# VITE_DEFAULT_API_TEMPERATURE=0.3
